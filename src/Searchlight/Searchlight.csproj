<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <TargetPlatformMinVersion>10.0.17763.0</TargetPlatformMinVersion>
    <RootNamespace>Searchlight</RootNamespace>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <ApplicationManifest>app.manifest</ApplicationManifest>
    <Platforms>x64;arm64</Platforms>
    <RuntimeIdentifiers>win-x64;win-arm64</RuntimeIdentifiers>
    <UseWinUI>true</UseWinUI>
    <!-- Embeds the exe icon (taskbar + Alt-Tab). Assets\app.ico is the multi-res
         (16..256) icon generated by tools\make_icon.py. -->
    <ApplicationIcon>Assets\app.ico</ApplicationIcon>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>

    <!-- We use field-based [ObservableProperty] (partial-property generation is not
         emitting implementations in this SDK combo). MVVMTK0045 only matters for AOT
         WinRT marshalling; this app is self-contained but not AOT-published. -->
    <NoWarn>$(NoWarn);MVVMTK0045</NoWarn>

    <!-- Unpackaged WinUI 3: run as a plain .exe, self-contained so no separate
         Windows App SDK runtime install is required. -->
    <WindowsPackageType>None</WindowsPackageType>
    <WindowsAppSDKSelfContained>true</WindowsAppSDKSelfContained>
    <EnableMsixTooling>true</EnableMsixTooling>
    <SelfContained>true</SelfContained>
    <AssemblyName>Searchlight</AssemblyName>
  </PropertyGroup>

  <!-- 'Demo' build configuration: compiles the app to boot against the synthetic
       MockSessionDataSource (no real ~/.copilot access) so the UI can be exercised
       and screenshotted without leaking proprietary session data. Selected via the
       USE_MOCK compile constant; the same behavior is also reachable at runtime in a
       normal build with the runtime demo command-line flag. -->
  <PropertyGroup Condition="'$(Configuration)' == 'Demo'">
    <DefineConstants>$(DefineConstants);USE_MOCK</DefineConstants>
    <Optimize>false</Optimize>
    <DebugType>portable</DebugType>
  </PropertyGroup>

  <ItemGroup>
    <!-- WindowsAppSDK 1.8 is the first line whose XamlCompiler handles .NET 10
         reference assemblies; 1.6's net472 XamlCompiler aborts (exit 1, no diagnostic)
         after codegen when compiling against net10.0 refs. H.NotifyIcon.WinUI 2.4.1
         depends on WinAppSDK >= 1.6, so it accepts 1.8. -->
    <PackageReference Include="Microsoft.WindowsAppSDK" Version="1.8.260529003" />
    <PackageReference Include="Microsoft.Windows.SDK.BuildTools" Version="10.0.26100.4654" />
    <PackageReference Include="H.NotifyIcon.WinUI" Version="2.4.1" />
    <PackageReference Include="CommunityToolkit.Mvvm" Version="8.4.0" />
    <PackageReference Include="Microsoft.Data.Sqlite" Version="9.0.0" />
    <!-- NU1903 (high-sev advisory GHSA-2m69-gcr7-jv3q / CVE-2025-6965) affects the
         native SQLite binary SQLitePCLRaw.lib.e_sqlite3 up to and including 2.1.11.
         The fix ships only in the realigned native package 3.50.3 (bundle/provider/core
         stay at 2.1.11). The native lib exposes a stable C ABI, so pinning just
         lib.e_sqlite3 to 3.50.3 clears the advisory while keeping the 2.1.11 managed
         provider that Microsoft.Data.Sqlite depends on.
         ASSUMPTION: lib.e_sqlite3 3.50.3 is ABI-compatible with SQLitePCLRaw.core 2.1.11
         (native package only realigned versioning to SQLite's version scheme). -->
    <PackageReference Include="SQLitePCLRaw.lib.e_sqlite3" Version="3.50.3" />
    <PackageReference Include="YamlDotNet" Version="16.3.0" />
    <!-- DI container (BuildServiceProvider lives in the full package; the Core lib
         only needs the Abstractions). The exe is the composition host. -->
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" Version="9.0.0" />
  </ItemGroup>

  <ItemGroup>
    <!-- Platform-neutral core: models, readers, view-models, and the data-source /
         dispatcher / watcher / resume abstractions. This WinUI exe is the Windows host. -->
    <ProjectReference Include="..\Searchlight.Core\Searchlight.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Content Include="Assets\**" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
